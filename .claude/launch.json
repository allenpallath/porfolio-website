{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "portfolio",
      "runtimeExecutable": "node",
      "runtimeArgs": ["-e", "const h=require('http'),f=require('fs'),p=require('path');h.createServer((q,r)=>{let u=q.url==='/'?'/index.html':q.url;let fp=p.join('D:/allen/allen.com',u);let ext=p.extname(fp);let ct={'html':'text/html','css':'text/css','js':'text/javascript'}[ext.slice(1)]||'application/octet-stream';f.readFile(fp,(e,d)=>{if(e){r.writeHead(404);r.end('Not found');}else{r.writeHead(200,{'Content-Type':ct});r.end(d);}});}).listen(3000)"],
      "port": 3000
    }
  ]
}